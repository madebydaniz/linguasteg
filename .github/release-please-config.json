{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": false,
  "always-link-local": true,
  "include-v-in-tag": true,
  "include-component-in-tag": true,
  "pull-request-header": "A new version is ready to be released 🚀",
  "bump-minor-pre-major": true,
  "plugins": ["cargo-workspace"],
  "changelog-sections": [
    {
      "type": "feat",
      "section": "✨ Features"
    },
    {
      "type": "fix",
      "section": "🐛 Bug Fixes"
    },
    {
      "type": "perf",
      "section": "⚡ Performance"
    },
    {
      "type": "refactor",
      "section": "🧱 Refactoring"
    },
    {
      "type": "style",
      "section": "🎨 Styles"
    },
    {
      "type": "test",
      "section": "✅ Tests"
    },
    {
      "type": "build",
      "section": "🏗️ Build System"
    },
    {
      "type": "deps",
      "section": "⬆️ Dependencies"
    },
    {
      "type": "docs",
      "section": "📜 Documentation"
    },
    {
      "type": "ci",
      "section": "♻️ CI/CD"
    },
    {
      "type": "chore",
      "section": "👽 Miscellaneous"
    },
    {
      "type": "release",
      "section": "🚀 Releases"
    },
    {
      "type": "revert",
      "section": "⏪ Reverts"
    },
    {
      "type": "security",
      "section": "🔐 Security"
    }
  ],
  "packages": {
    "linguasteg": {
      "component": "linguasteg",
      "release-type": "rust",
      "package-name": "linguasteg"
    },
    "linguasteg-core": {
      "component": "linguasteg-core",
      "release-type": "rust",
      "package-name": "linguasteg-core"
    },
    "linguasteg-models": {
      "component": "linguasteg-models",
      "release-type": "rust",
      "package-name": "linguasteg-models"
    },
    "linguasteg-cli": {
      "component": "linguasteg-cli",
      "release-type": "rust",
      "package-name": "linguasteg-cli"
    },
    "linguasteg-eval": {
      "component": "linguasteg-eval",
      "release-type": "rust",
      "package-name": "linguasteg-eval"
    }
  }
}
